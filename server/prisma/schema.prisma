generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(cuid())
  username  String  @unique
  password  String
  folders   Folder[]
}

model Folder {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields:[userId], references: [id])
}